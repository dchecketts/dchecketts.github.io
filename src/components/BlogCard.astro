---
interface Props {
  url: string | undefined;
  title: string;
  pubDate: string;
  description: string;
  tags?: string[];
  image?: string;
}

const { url, title, pubDate, description, tags } = Astro.props;
---

<li class="surface-card surface-card-hover overflow-hidden">
  <a href={url} hx-boost="true" class="block h-full p-6">
    <div class="space-y-4">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold tracking-tight text-stone-900">
          {title}
        </h2>

        <p class="text-sm text-stone-500">
          {new Date(pubDate).toLocaleDateString()}
        </p>

        <p class="text-sm leading-6 text-stone-700">
          {description}
        </p>
      </div>

      {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-2">
            {tags.map((tag) => (
                <span class="rounded-full bg-stone-100 px-2.5 py-1 text-xs font-medium text-stone-700">
              #{tag}
            </span>
            ))}
          </div>
      )}
    </div>
  </a>
</li>