---
const year = new Date().getFullYear()

import Link from '../components/mdx/Link.astro'

const linkItem = "text-sm text-emerald-100 underline-offset-4 transition-colors hover:text-white hover:underline focus-visible:outline-white"
---

<footer class="border-t border-emerald-950/20 bg-emerald-950 text-white">
  <div class="site-container flex flex-col gap-4 py-6 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-emerald-100">&copy; {year} Daniel Checketts. All rights reserved.</p>

    <nav aria-label="Footer links">
      <ul class="flex flex-wrap gap-4">
        <li><Link url="https://www.facebook.com/manny.checketts" type="footer" external={true}>Facebook</Link></li>
        <li><Link url="https://www.linkedin.com/in/danielchecketts" type="footer" external={true}>LinkedIn</Link></li>
        <li><Link url="https://www.github.com/dchecketts" type="footer" external={true}>GitHub</Link></li>
      </ul>
    </nav>
  </div>
</footer>