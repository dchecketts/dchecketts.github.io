---
// Accept both language and data-language props for flexibility
const { language, "data-language": dataLanguage } = Astro.props;
const rawLang = (language || dataLanguage || "text").toString().trim().toLowerCase();

const prettyMap = {
  js: "JavaScript",
  javascript: "JavaScript",
  ts: "TypeScript",
  typescript: "TypeScript",
  py: "Python",
  python: "Python",
  rb: "Ruby",
  java: "Java",
  css: "CSS",
  html: "HTML",
  json: "JSON",
  sh: "Shell",
  bash: "Shell",
  text: "Text"
};

const lang = prettyMap[rawLang] || (rawLang ? rawLang[0].toUpperCase() + rawLang.slice(1) : "Text");
---
<div class="code-container bg-gray-900 rounded-lg p-4 my-6 font-mono text-sm relative shadow-inner group overflow-hidden">
  <div class="flex justify-between items-center mb-2 pb-2 border-b border-gray-800 select-none">
    <span class="text-xs text-gray-500 uppercase font-semibold tracking-wider">{lang}</span>

    <button
      class="copy-btn p-1.5 rounded text-gray-400 hover:bg-gray-800 hover:text-white transition-all active:scale-95"
      aria-label="Copy code to clipboard"
      type="button"
    >
      <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
      </svg>
      <svg class="success-icon h-4 w-4 hidden text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </button>
  </div>

  <div class="overflow-x-auto pre-content text-gray-100">
    <slot />
  </div>
</div>

<style is:global>
    .pre-content pre {
        background-color: transparent !important;
        counter-reset: line;
        display: table;
        width: 100%;
        padding: 0 !important;
        margin: 0 !important;
    }

    .pre-content pre .line {
        display: table-row;
    }

    .pre-content pre .line::before {
        counter-increment: line;
        content: counter(line);
        display: table-cell;
        text-align: right;
        padding-right: 1.25rem;
        user-select: none;
        opacity: 0.35;
        font-size: 0.8rem;
        width: 1rem;
    }

    .code-container pre {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, "Roboto Mono", "Segoe UI Mono", "Noto Mono", monospace;
        font-size: 0.9rem;
        line-height: 1.45;
    }
</style>

<script>
  (function () {
    if (window["__codeBlockCopyHandlerInstalled"]) return;
    window["__codeBlockCopyHandlerInstalled"] = true;

    document.addEventListener('click', async (event) => {
      const targetEl = event.target instanceof Element ? event.target : null;
      if (!targetEl) return;

      const btn = targetEl.closest('.copy-btn');
      if (!btn) return;

      const container = btn.closest('.code-container');
      if (!container) return;

      let pre = container.querySelector('pre');
      if (!pre) pre = container.querySelector('code');
      if (!pre) return;

      const codeToCopy = pre.textContent || '';
      const copyIcon = btn.querySelector('.copy-icon');
      const successIcon = btn.querySelector('.success-icon');

      try {
        await navigator.clipboard.writeText(codeToCopy);
        if (copyIcon) copyIcon.classList.add('hidden');
        if (successIcon) successIcon.classList.remove('hidden');

        setTimeout(() => {
          if (copyIcon) copyIcon.classList.remove('hidden');
          if (successIcon) successIcon.classList.add('hidden');
        }, 2000);
      } catch (err) {
        try {
          const ta = document.createElement('textarea');
          ta.value = codeToCopy;
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);

          if (copyIcon) copyIcon.classList.add('hidden');
          if (successIcon) successIcon.classList.remove('hidden');

          setTimeout(() => {
            if (copyIcon) copyIcon.classList.remove('hidden');
            if (successIcon) successIcon.classList.add('hidden');
          }, 2000);
        } catch (err2) {
          console.error('Failed to copy code:', err, err2);
        }
      }
    });
  })();
</script>