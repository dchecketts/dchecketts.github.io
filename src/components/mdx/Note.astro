---
const { type = "info" } = Astro.props;

const styles: Record<string, string> = {
  warning: "bg-amber-50 border-amber-500 text-amber-900",
  info: "bg-blue-50 border-blue-500 text-blue-900",
  success: "bg-emerald-50 border-emerald-500 text-emerald-900",
  danger: "bg-red-50 border-red-500 text-red-900"
};

const className = styles[type] ?? styles.info;
---

<div class={`p-4 border-l-4 rounded-r my-6 ${className}`}>
  <p class="font-bold capitalize mb-1">{type && (type.toLowerCase() === "success" ? "Success!" : type.toLowerCase() === "danger" ? "Danger!" : type.toLowerCase() === "warning" ? "Warning!" : type)}</p>
  <div class="text-sm"><slot /></div>
</div>