---
const { color = "yellow"} = Astro.props

const styles: Record<string, string> = {
    red: "bg-red-300",
    orange: "bg-orange-300",
    yellow: "bg-yellow-300",
    green: "bg-green-300",
    blue: "bg-blue-300",
    purple: "bg-purple-300",
    redacted: "bg-black text-black"
}

const className = styles[color] ?? styles.yellow
---

<span class={`rounded-md py-0.5 px-1 ${className}`}><slot /></span>