---
import BaseLayout from '../layouts/BaseLayout.astro'
import BlogCard from '../components/BlogCard.astro'

const pageName = "Blog"

const markdownFiles = import.meta.glob('./blog/*.mdx', { eager: true })
const posts = Object.values(markdownFiles) as Array<{ url: string; frontmatter: { title: string; pubDate: string; description: string; tags: string[] } }>
---

<BaseLayout pageTitle={pageName}>
  <div class="space-y-8">
    <header class="space-y-4">
      <h1 class="page-heading">{pageName}</h1>
      <p class="max-w-2xl text-base leading-7 text-stone-700">
        Notes, articles, and reflections on programming, learning, and the work I’m building.
      </p>
    </header>

    <ul class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {posts.map((post) => (
          <BlogCard
              url={post.url}
              title={post.frontmatter.title}
              pubDate={post.frontmatter.pubDate}
              description={post.frontmatter.description}
              tags={post.frontmatter.tags}
          />
      ))}
    </ul>
  </div>
</BaseLayout>